rules_version = '2';

// ─── NOTE ON ADMIN LIST ─────────────────────────────────────────
// There is NO admin whitelist here. The single source of truth for
// admin emails is src/utils/rollParser.js → ADMIN_EMAILS.
// These rules enforce authentication only. Admin-gating (upload,
// delete, update) is enforced in the React app.
//
// For a small internal tool this is appropriate. If you need
// server-side admin enforcement in the future, use Firebase Custom
// Claims (see README) instead of duplicating the email list here.
// ───────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{filename} {
      // Any authenticated user may read (students fetch their own photo via signed URL)
      allow read: if request.auth != null;

      // Any authenticated user may write — app enforces admin-only UI
      allow write: if request.auth != null;
    }
  }
}

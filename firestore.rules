rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin list - update this to match your actual admins
    function isAdmin() {
      return request.auth.token.email in [
        'admin@cfd.nu.edu.pk'
        // Add more admin emails here
      ];
    }

    function isUniversityEmail() {
      return request.auth.token.email.matches('.*@cfd\\.nu\\.edu\\.pk');
    }

    match /students/{rollNumber} {
      allow read: if request.auth != null && (
        isAdmin() || (isUniversityEmail() && resource.id == rollNumber)
      );
      allow write: if request.auth != null && isAdmin();
    }
  }
}

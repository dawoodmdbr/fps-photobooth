rules_version = '2';

// ─── NOTE ON ADMIN LIST ─────────────────────────────────────────
// There is NO admin whitelist here. The single source of truth for
// admin emails is src/utils/rollParser.js → ADMIN_EMAILS.
// These rules enforce authentication only.
// ───────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    match /students/{rollNumber} {
      // Any authenticated user can read — app shows only their own data
      allow read: if request.auth != null;

      // Any authenticated user can write — app enforces admin-only UI
      allow write: if request.auth != null;
    }
  }
}
